# Copy to .env and fill in. Local dev uses the Docker Postgres (see docker-compose.yml).
DATABASE_URL="postgresql://dataops:dataops@localhost:5432/dataops?schema=public"

# Anthropic API — required for AI Daily Summary and Risk Flags features.
ANTHROPIC_API_KEY="sk-ant-..."
# Any current Claude model id. See https://docs.claude.com for the model list.
ANTHROPIC_MODEL="claude-sonnet-4-6"
