# Copy to .env and fill in. Local dev uses the Docker Postgres (see docker-compose.yml).
DATABASE_URL="postgresql://dataops:dataops@localhost:5432/dataops?schema=public"

# AI features (Daily Summary + Risk Flags) — set ONE provider's key.
# The provider is auto-detected from whichever key is present; override with
# AI_PROVIDER if both are set.
# AI_PROVIDER="openai"   # or "anthropic"

# OpenAI — uses structured outputs (json_schema, strict) for the risk flags.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Anthropic — uses the Messages API with forced tool-use for the risk flags.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
